import("//build/config/features.gni")
import("//build/test.gni")
import("//foundation/graphic/graphic_3d/lume/lume_config.gni")

ohos_fuzztest("GltfLoadFuzzTest") {
  module_out_path = "graphic_3d/lume_scene"
  fuzz_config_file = "."

  configs = [
    "${LUME_BASE_PATH}:lume_base_api_config",
    "${LUME_CORE_PATH}:lume_engine_api",
    "${LUME_RENDER_PATH}:lume_render_api",
    "${LUME_CORE3D_PATH}:lume_3d_api",
    "${LUME_CORE_PATH}:lume_default",
  ]

  sources = [ "gltf_load_fuzzer.cpp" ]

  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
  ]

  deps = [
    "${LUME_ECS_HELPER_PATH}:libAGPEcshelper",
  ]

  external_deps = [
    "bounds_checking_function:libsec_shared",
    "c_utils:utils",
    "hilog:libhilog",
  ]

  if (RENDER_BUILD_GLES) {
    external_deps += [
      "graphic_2d:EGL",
      "graphic_2d:GLESv3",
    ]
  }

  if (RENDER_BUILD_VULKAN) {
    external_deps += [
      "vulkan-headers:vulkan_headers",
      "vulkan-loader:vulkan_loader",
    ]
  }

  part_name = "graphic_3d"
  subsystem_name = "graphic"
}

group("fuzztest") {
  testonly = true
  deps = [ ":GltfLoadFuzzTest" ]
}
