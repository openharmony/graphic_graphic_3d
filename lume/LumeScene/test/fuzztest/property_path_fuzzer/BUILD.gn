import("//build/config/features.gni")
import("//build/test.gni")
import("//foundation/graphic/graphic_3d/lume/lume_config.gni")

ohos_fuzztest("PropertyPathFuzzTest") {
  module_out_path = "graphic_3d/lume_scene"
  fuzz_config_file = "."

  configs = [
    "${LUME_BASE_PATH}:lume_base_api_config",
    "${LUME_CORE_PATH}:lume_engine_api",
    "${LUME_META_PATH}:lume_meta_api_config",
    "${LUME_SCENE_PATH}:lume_scene_api_config",
  ]

  sources = [ "property_path_fuzzer.cpp" ]

  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
  ]

  deps = [
    "${LUME_META_PATH}:libPluginMetaObject",
  ]

  external_deps = [
    "bounds_checking_function:libsec_shared",
    "c_utils:utils",
    "hilog:libhilog",
  ]

  part_name = "graphic_3d"
  subsystem_name = "graphic"
}

group("fuzztest") {
  testonly = true
  deps = [ ":PropertyPathFuzzTest" ]
}
