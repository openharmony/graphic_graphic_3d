import("//build/test.gni")
import("//build/ohos.gni")
import("//foundation/graphic/graphic_3d/lume/lume_config.gni")

module_output_path = "graphic_3d/graphic_3d/lume/LumePng"

ohos_unittest("lume_png_src_test") {
  module_out_path = module_output_path

  configs = [
    "${LUME_BASE_PATH}:lume_base_api_config",
    "${LUME_BASE_PATH}:lume_unit_test_config",
    "${LUME_PNG_PATH}:lume_png_config",
    "${LUME_PNG_PATH}:lume_png_api",
    "${LUME_CORE_PATH}:lume_engine_api",
  ]

  include_dirs = [
    "common",
    "src_unit_test/src",
  ]

  sources = [
    "common/test_runner_ohos_system.cpp",
    "src_unit_test/src/image_loader_png_test.cpp",
  ]

  deps = [
    "${LUME_PNG_PATH}:lume_png_src",
  ]

  external_deps = [
    "bounds_checking_function:libsec_shared",
    "c_utils:utils",
    "googletest:gtest",
    "googletest:gmock",
    "libpng:libpng",
  ]

  defines = [
    "private=public",
    "protected=public",
  ]

  part_name = "graphic_3d"
  subsystem_name = "graphic"
}

group("unittest") {
  testonly = true
  deps = [ ":lume_png_src_test" ]
}
